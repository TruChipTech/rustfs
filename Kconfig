mainmenu "RustFS Configuration"

menu "Init System"

config INIT
    bool "Enable init applet"
    default y
    help
      Enable the init applet, allowing RustFS to serve as PID 1
      (the first userspace process started by the Linux kernel).

choice
    prompt "Init system type"
    depends on INIT
    default INIT_RUSTFS

config INIT_RUSTFS
    bool "RustFS init (simple init)"
    help
      Simple, lightweight init similar in spirit to minimal init
      implementations. Reads /etc/inittab, manages process spawning
      and respawning, mounts essential filesystems, and runs
      rc scripts. Ideal for embedded systems and containers.

config INIT_SYSVINIT
    bool "System V init"
    help
      Full System V init support. Parses /etc/inittab and manages
      runlevels (0-6, S). Supports respawn, wait, once, sysinit,
      boot, bootwait, ctrlaltdel, shutdown, and restart actions.
      Provides telinit functionality for runlevel switching.

config INIT_SYSTEMD
    bool "systemd-compatible init"
    help
      systemd-compatible init. Parses .service unit files from
      /etc/systemd/system/ and /usr/lib/systemd/system/.
      Supports Type=simple, forking, oneshot. Handles ExecStart,
      ExecStop, Restart, WantedBy, After, and Requires directives.
      Resolves service dependencies and starts them in order.

endchoice

endmenu

menu "Device Manager"

config MDEV
    bool "mdev — lightweight device manager"
    default y
    help
      Lightweight device manager that handles hotplug events from
      the kernel via /sys. Reads /etc/mdev.conf for device node
      creation rules (permissions, ownership, symlinks, scripts).
      Suitable for embedded systems and minimal rootfs setups.

config UDEV
    bool "udev — full device manager"
    default n
    help
      udev-compatible device manager. Listens on a netlink socket
      for kernel uevents and creates/removes device nodes in /dev.
      Reads rules from /etc/udev/rules.d/ and /usr/lib/udev/rules.d/.
      Supports SUBSYSTEM, KERNEL, ATTR, SYMLINK, RUN, MODE, OWNER,
      GROUP, and ENV matching/assignment keys.

endmenu

